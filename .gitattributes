* text=auto

# Keep source files as LF in the repository
*.c   text eol=lf
*.h   text eol=lf
*.s   text eol=lf
*.ld  text eol=lf
*.txt text eol=lf
*.md  text eol=lf
*.cmake text eol=lf

# Windows scripts can stay CRLF if you have any
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.bin binary
*.elf binary
*.hex binary